# Copia este archivo como .env y ajusta los valores.
#   copy .env.example .env

FLASK_ENV=development
SECRET_KEY=cambiar-por-una-clave-segura-en-produccion

# --- Opción A: SQLite (desarrollo rápido, sin instalar servidor) ---
# DATABASE_URL=sqlite:///bienestar.db

# --- Opción B: PostgreSQL (recomendado para producción) ---
DATABASE_URL=postgresql://bienestar_user:bienestar_pass@localhost:5432/bienestar

OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b
